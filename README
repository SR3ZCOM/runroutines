extern "C" fn task1(data: *mut ()) {
  let msg = unsafe { *Box::from_raw(data as *mut String) };
  println!("⚠️  TASK_1: {}", msg);
}
----------------------------------------------------------------------------------------

build_runtime(2);
RunroutineStruct::add(task1, String::from("new_msg"));
